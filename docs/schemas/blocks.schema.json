{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://captionpanels.local/schemas/blocks.schema.json",
  "title": "CaptionPanels Blocks JSON",
  "type": "object",
  "required": ["schemaVersion", "source", "blocks"],
  "properties": {
    "schemaVersion": { "type": "number" },
    "source": {
      "type": "object",
      "required": ["compName", "fps"],
      "properties": {
        "engine": { "type": "string" },
        "aeVersion": { "type": "string" },
        "compName": { "type": "string" },
        "fps": { "type": "number", "exclusiveMinimum": 0 },
        "exportedAt": { "type": "string" }
      },
      "additionalProperties": true
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["segId", "text", "start", "end"],
        "properties": {
          "segId": { "type": "string", "minLength": 1 },
          "text": { "type": "string" },
          "start": { "type": "number" },
          "end": { "type": "number" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
