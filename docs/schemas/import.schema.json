{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://captionpanels.local/schemas/import.schema.json",
  "title": "CaptionPanels Import JSON",
  "type": "object",
  "required": ["segments"],
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "rubric": { "type": "string" }
      },
      "additionalProperties": true
    },
    "speakers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": ["string", "number"] },
          "name": { "type": "string" },
          "role": { "type": "string" },
          "job": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["voiceover", "sync", "synch", "geotag"]
          },
          "text": { "type": "string" },
          "speakerId": { "type": ["string", "number"] },
          "pin": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
