{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CaptionPanels alignment.json",
  "type": "object",
  "required": ["schemaVersion", "blocks", "unmatched"],
  "properties": {
    "schemaVersion": { "type": "integer", "enum": [1] },
    "source": { "type": "object" },
    "settings": {
      "type": "object",
      "properties": {
        "padStartFrames": { "type": "number" },
        "padEndFrames": { "type": "number" },
        "minDurationFrames": { "type": "number" }
      }
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["segId", "start", "end"],
        "properties": {
          "segId": { "type": "string" },
          "start": { "type": "number" },
          "end": { "type": "number" },
          "confidence": { "type": "number" }
        }
      }
    },
    "unmatched": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["segId", "reason"],
        "properties": {
          "segId": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
